<UserControl x:Class="StudyAndOrder.Wpf.Views.StudyInformationScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Email:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Row 1 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="WBS:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 Text="{Binding WBS, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Row 2 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Cost_Center:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 Text="{Binding CostCenter, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- Row 3 -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Facility:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="3" Grid.Column="1"
                  SelectedItem="{Binding Facility, UpdateSourceTrigger=PropertyChanged}">
            <ComboBoxItem Content="Alpha"/>
            <ComboBoxItem Content="Omega"/>
            <ComboBoxItem Content="Alpha and/or Omega"/>
        </ComboBox>

        <!-- Row 4 -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="From_Date:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="4" Grid.Column="1"
                    SelectedDate="{Binding FromDate}"/>

        <!-- Row 5 -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="To_Date:" VerticalAlignment="Center"/>
        <DatePicker Grid.Row="5" Grid.Column="1"
                    SelectedDate="{Binding ToDate}"/>

        <!-- Row 6 -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Process_Order_Type:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="6" Grid.Column="1"
                  ItemsSource="{Binding ProcessOrderTypeValues}"
                  SelectedItem="{Binding ProcessOrderType}"/>

        <!-- Row 7 -->
        <CheckBox Grid.Row="7" Grid.Column="1"
                  Content="Data_Equipment_Validation"
                  IsChecked="{Binding DataEquipmentValidation}"/>

        <!-- Row 8 -->
        <CheckBox Grid.Row="8" Grid.Column="1"
                  Content="Sampling_Stock"
                  IsChecked="{Binding SamplingStock}"/>

        <!-- Row 9 (Created order nederst til højre) -->
        <Button Grid.Row="9" Grid.Column="1"
                Content="Created order"
                Command="{Binding CreatedOrderCommand}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,10,0,0"
                Padding="12,6"/>
    </Grid>
</UserControl>